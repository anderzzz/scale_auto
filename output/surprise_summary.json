      "beta_cars": 0.6658,
      "income_coef": {
        "coef": -1.9823,
        "se": 0.2366,
        "p": 5.2896504945619727e-17
      },
      "tourism_coef": {
        "coef": 0.1694,
        "se": 0.0208,
        "p": 3.666701471249318e-16
      },
      "alpha": null,
      "dispersion": 0.841
    }
  },
  "income_effect": {
    "coef": -2.4988,
    "se": 0.2251,
    "p": 1.2657030522768544e-28,
    "interpretation": "holding cars fixed, higher median income is associated with FEWER petrol stations (significant)"
  },
  "tourism_effect": {
    "coef": 0.1694,
    "se": 0.0208,
    "p": 3.666701471249318e-16,
    "proxy": "log1p(accommodation + ski-lift POIs from OSM)",
    "interpretation": "holding cars & income fixed, more tourism POIs are associated with MORE petrol stations \u2014 a visitor 'effective customer base' (significant)"
