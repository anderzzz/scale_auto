{
  "primary_model": "cars_income_tourism",
  "exposure_note": "PRIMARY exposure = registered cars (Phase 7); population & cars+income kept for comparison. Cars year=2025, income year=2024.",
  "models": {
    "population": {
      "exposure": "population",
      "beta": 0.5918,
